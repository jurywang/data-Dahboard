        // -------------------------- 模拟数据生成函数 --------------------------
        function generateMockData(app, metric, timePeriod) {
            let baseMultiplier = 1;
            const category1 = app.category1;
            if (category1 === 'content-entertainment') baseMultiplier *= 1.5;
            if (category1 === 'social-communication') baseMultiplier *= 1.8;
            if (category1 === 'system-tool') baseMultiplier *= 1.2;
            if (category1 === 'finance-investment') baseMultiplier *= 1.3;

            let nameMultiplier = 1;
            const hotApps = ['微信', '抖音', '应用市场', '浏览器', 'QQ', '支付宝', '淘宝'];
            const midApps = ['音乐', '视频', '游戏中心', '地图', '快手', '京东', '美团', 'B站', '小红书', '钱包'];
            if (hotApps.includes(app.name)) nameMultiplier *= 2.0;
            if (midApps.includes(app.name)) nameMultiplier *= 1.5;

            let regionMultiplier = 1;
            if (state.region === 'domestic') regionMultiplier *= 1.2;
            if (state.region === 'overseas') regionMultiplier *= 0.6;

            let caliberMultiplier = state.caliber === 'account' ? 0.8 : 1.0;
            
            // 设备类型影响因子
            let deviceMultiplier = 1;
            if (state.deviceType.includes('phone')) deviceMultiplier *= 1.0;
            if (state.deviceType.includes('tablet')) deviceMultiplier *= 0.7;
            if (state.deviceType.includes('pc')) deviceMultiplier *= 0.5;
            if (state.deviceType.includes('tv')) deviceMultiplier *= 0.6;
            if (state.deviceType.includes('watch')) deviceMultiplier *= 0.3;
            if (state.deviceType.includes('car')) deviceMultiplier *= 0.4;
            if (state.deviceType.includes('speaker')) deviceMultiplier *= 0.2;
            if (state.deviceType.includes('glasses')) deviceMultiplier *= 0.1;
            if (state.deviceType.includes('headphone')) deviceMultiplier *= 0.2;
            
            // 单双框影响因子
            let frameMultiplier = 1;
            if (state.frame === 'single') frameMultiplier *= 0.8;
            if (state.frame === 'double') frameMultiplier *= 1.2;
            
            let timeMultiplier = 0.9 + Math.random() * 0.2;

            let baseValue = 0;
            switch (metric) {
                case 'dau': baseValue = 1000; break;
                case 'mau': baseValue = 5000; break;
                case 'daily-duration': baseValue = 30; break;
                case 'daily-launches': baseValue = 10; break;
                case 'biz-duration': baseValue = 15; break;
                case 'biz-launches': baseValue = 5; break;
                case 'arpu': baseValue = 2; break;
                case 'arppu': baseValue = 50; break;
                case 'pay-user': baseValue = 50; break;
                case 'pay-member': baseValue = 300; break;
                case 'app-market-download': baseValue = 2.5; break;
                case 'ad-ecpm': baseValue = 25; break;
                case 'ad-clients': baseValue = 1200; break;
                case 'non-huawei-ad-revenue': baseValue = 65; break;
                case 'card-stock': baseValue = 8000; break;
                case 'payment-flow': baseValue = 50000; break;
                case 'huawei-pay-penetration': baseValue = 45; break;
                case 'card-binding-rate': baseValue = 32; break;
                case 'total-card-binding-users': baseValue = 12000; break;
            }

            if (['ad-clients', 'card-stock', 'total-card-binding-users'].includes(metric)) {
                if (timePeriod === 'month') timeMultiplier = 1.0;
                if (timePeriod === 'quarter') timeMultiplier = 1.2 + Math.random() * 0.3;
                if (timePeriod === 'year') timeMultiplier = 1.5 + Math.random() * 0.5;
            }

            let finalValue = baseValue * baseMultiplier * nameMultiplier * regionMultiplier * caliberMultiplier * deviceMultiplier * frameMultiplier * timeMultiplier;

            // 生成同环比
            let mom = (Math.random() * 0.2 - 0.1);
            let yoy = (Math.random() * 0.3 - 0.1);

            const unitMap = {
                dau: '万', mau: '万', 'pay-user': '万', 'pay-member': '万',
                'card-stock': '万张', 'total-card-binding-users': '万',
                'daily-duration': '分钟', 'biz-duration': '分钟',
                'daily-launches': '次', 'biz-launches': '次',
                arpu: '元', arppu: '元', 'payment-flow': '万元',
                'app-market-download': '个', 'ad-ecpm': '元',
                'ad-clients': '家', 'non-huawei-ad-revenue': '%',
                'huawei-pay-penetration': '%', 'card-binding-rate': '%'
            };
            const unit = unitMap[metric];

            let formattedValue = '';
            if (['dau', 'mau', 'pay-user', 'pay-member', 'card-stock', 'total-card-binding-users', 'ad-clients'].includes(metric)) {
                formattedValue = Math.round(finalValue) + unit;
            } else if (['non-huawei-ad-revenue', 'huawei-pay-penetration', 'card-binding-rate'].includes(metric)) {
                formattedValue = Math.min(Math.round(finalValue * 10) / 10, 95) + unit;
            } else {
                formattedValue = Math.round(finalValue * 10) / 10 + unit;
            }

            return {
                value: formattedValue,
                mom: mom,
                yoy: yoy,
                rawValue: finalValue,
                metric: metric
            };
        }

