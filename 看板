        // -------------------------- 多指标表格渲染函数 --------------------------
        function renderTable() {
            // 1. 筛选应用列表
            let appsToShow = [];
            if (state.appType.includes('first-party')) appsToShow = appsToShow.concat(firstPartyApps);
            if (state.appType.includes('third-party')) appsToShow = appsToShow.concat(thirdPartyApps);

            if (state.appCategory.length > 0 && state.appCategory.length < 10) {
                appsToShow = appsToShow.filter(app => state.appCategory.includes(app.category1));
            }

            if (state.subCategory.length > 0) {
                appsToShow = appsToShow.filter(app => state.subCategory.includes(app.category2));
            }

            if (state.appName) {
                const searchTerm = state.appName.toLowerCase();
                appsToShow = appsToShow.filter(app => app.name.toLowerCase().includes(searchTerm));
            }

            // 2. 生成表头
            const table = document.getElementById('dataTable');
            const selectedMetrics = state.selectedMetrics;

            // 固定基础列
            let tableHTML = '<thead><tr><th>应用名称</th><th>一级分类</th><th>二级分类</th>';

            // 每个选中指标生成一组列
            selectedMetrics.forEach(metricKey => {
                const metricConfig = metricDefinitions[metricKey];
                const columnName = metricConfig.timePeriodDesc[state.currentTimePeriod];
                tableHTML += `<th colspan="3">${metricConfig.title} - ${columnName}</th>`;
                // 渗透率列
                if (metricConfig.extraColumn) {
                    tableHTML += `<th>${metricConfig.extraColumn.name}</th>`;
                }
            });
            tableHTML += '</tr><tr>';
            // 固定列的空表头
            tableHTML += '<th></th><th></th><th></th>';
            // 每个指标的子表头
            selectedMetrics.forEach(metricKey => {
                const metricConfig = metricDefinitions[metricKey];
                tableHTML += '<th>指标值</th><th>环比</th><th>同比</th>';
                if (metricConfig.extraColumn) {
                    tableHTML += '<th></th>';
                }
            });
            tableHTML += '</tr></thead><tbody>';

            // 3. 生成表体数据
            const appDataList = []; // 存储应用数据，用于后续解读
            appsToShow.forEach(app => {
                let rowHTML = `<tr><td>${app.name}</td><td>${categoryNameMap[app.category1]}</td><td>${app.category2}</td>`;
                const appData = { name: app.name, category1: app.category1, metrics: {} };

                // 遍历每个选中的指标
                selectedMetrics.forEach(metricKey => {
                    const data = generateMockData(app, metricKey, state.currentTimePeriod);
                    appData.metrics[metricKey] = data;

                    // 同环比格式化
                    const momClass = data.mom >= 0 ? 'mom-positive' : 'mom-negative';
                    const momSign = data.mom >= 0 ? '+' : '';
                    const momStr = momSign + (data.mom * 100).toFixed(1) + '%';

                    const yoyClass = data.yoy >= 0 ? 'yoy-positive' : 'yoy-negative';
                    const yoySign = data.yoy >= 0 ? '+' : '';
                    const yoyStr = yoySign + (data.yoy * 100).toFixed(1) + '%';

                    // 指标值+同环比列
                    rowHTML += `<td>${data.value}</td><td class="${momClass}">${momStr}</td><td class="${yoyClass}">${yoyStr}</td>`;

                    // 渗透率列
                    const metricConfig = metricDefinitions[metricKey];
                    if (metricConfig.extraColumn) {
                        let penetration = '-';
                        if (metricKey === 'mau') {
                            const base = MARKET_BASE[state.region][state.caliber].totalMAU;
                            const val = parseFloat(data.value.replace(/[^0-9.]/g, ''));
                            penetration = ((val / base) * 100).toFixed(2) + '%';
                        } else if (metricKey === 'pay-user') {
                            const base = MARKET_BASE[state.region][state.caliber].avgDAU;
                            const val = parseFloat(data.value.replace(/[^0-9.]/g, ''));
                            penetration = ((val / base) * 100).toFixed(2) + '%';
                        } else if (metricKey === 'pay-member') {
                            const base = MARKET_BASE[state.region][state.caliber].totalMAU;
                            const val = parseFloat(data.value.replace(/[^0-9.]/g, ''));
                            penetration = ((val / base) * 100).toFixed(2) + '%';
                        }
                        rowHTML += `<td>${penetration}</td>`;
                    }
                });

                rowHTML += `</tr>`;
                tableHTML += rowHTML;
                appDataList.push(appData);
            });

            tableHTML += '</tbody>';
            table.innerHTML = tableHTML;

            // 4. 添加表格点击事件
            setTimeout(addTableClickEvents, 100);
        }

