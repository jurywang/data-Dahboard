        // -------------------------- 图表生成功能 --------------------------
        // 生成应用历史数据
        function generateAppHistoryData(appName, metric) {
            let timeLabels = [];
            let trendFactor = 1;
            
            // 根据当前选择的时间周期生成对应的时间标签
            switch (state.currentTimePeriod) {
                case 'day':
                    timeLabels = ['1日', '2日', '3日', '4日', '5日', '6日'];
                    break;
                case 'week':
                    timeLabels = ['第1周', '第2周', '第3周', '第4周', '第5周', '第6周'];
                    break;
                case 'month':
                    timeLabels = ['1月', '2月', '3月', '4月', '5月', '6月'];
                    break;
                case 'bimonth':
                    timeLabels = ['1-2月', '3-4月', '5-6月', '7-8月', '9-10月', '11-12月'];
                    break;
                case 'quarter':
                    timeLabels = ['Q1', 'Q2', 'Q3', 'Q4', 'Q1', 'Q2'];
                    break;
                case 'year':
                    timeLabels = ['2022', '2023', '2024', '2025', '2026', '2027'];
                    break;
                default:
                    timeLabels = ['1月', '2月', '3月', '4月', '5月', '6月'];
            }
            
            // 根据应用名称设置趋势因子
            const risingApps = ['汽水音乐', '抖音', '快手', '小红书'];
            const decliningApps = ['QQ音乐', '酷狗音乐', '网易云音乐'];
            
            if (risingApps.includes(appName)) {
                trendFactor = 1.05; // 上升趋势
            } else if (decliningApps.includes(appName)) {
                trendFactor = 0.95; // 下降趋势
            }
            
            const data = [];
            let baseValue = 1000;
            
            // 根据指标类型设置基础值
            if (metric === 'dau') baseValue = 1000;
            if (metric === 'mau') baseValue = 5000;
            if (metric === 'daily-duration') baseValue = 30;
            if (metric === 'daily-launches') baseValue = 10;
            if (metric === 'arpu') baseValue = 2;
            
            // 根据应用名称调整基础值
            if (appName === '微信') baseValue *= 5;
            if (appName === '抖音') baseValue *= 3;
            if (appName === 'QQ音乐') baseValue *= 1.5;
            if (appName === '汽水音乐') baseValue *= 2;
            
            let currentValue = baseValue * (0.8 + Math.random() * 0.4);
            
            for (let i = 0; i < timeLabels.length; i++) {
                // 应用趋势因子
                currentValue *= trendFactor;
                // 添加一些随机波动
                const change = (Math.random() * 0.1 - 0.05);
                currentValue = currentValue * (1 + change);
                data.push(Math.round(currentValue));
            }
            
            return {
                labels: timeLabels,
                data: data
            };
        }

        // 生成应用对比数据
        function generateAppComparisonData(apps, metric) {
            const data = [];
            const appNames = [];
            
            apps.forEach(app => {
                appNames.push(app.name);
                const mockData = generateMockData(app, metric, state.currentTimePeriod);
                data.push(Math.round(mockData.rawValue));
            });
            
            return {
                appNames: appNames,
                data: data
            };
        }

