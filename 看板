<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>终端云服务数据看板：为硬件带来体验价值，依托硬件实现运营价值</title>
    <!-- 引入ECharts（预留图表切换能力） -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/echarts/5.4.3/echarts.min.js"></script>
    <style>
        /* -------------------------- 华为品牌配色系统 -------------------------- */
        :root {
            --huawei-red: #CF0A2C;
            --huawei-red-light: #E64340;
            --huawei-red-dark: #A60000;
            --bg-gray: #F5F5F5;
            --bg-white: #FFFFFF;
            --text-primary: #333333;
            --text-secondary: #666666;
            --text-tertiary: #999999;
            --border-color: #E5E5E5;
            --hover-bg: #FFF0F0;
            --positive-green: #52c41a;
            --negative-red: #ff4d4f;
        }

        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            font-family: 'HarmonyOS Sans SC', 'Microsoft YaHei', sans-serif; 
        }

        body { 
            background-color: var(--bg-gray); 
            color: var(--text-primary);
            line-height: 1.6;
        }

        /* -------------------------- 顶部导航栏 -------------------------- */
        .top-nav {
            background: var(--bg-white);
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }

        .nav-header {
            padding: 15px 30px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-title {
            font-size: 20px;
            font-weight: bold;
            color: var(--huawei-red);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* API Key输入样式 */
        .api-key-section {
            background: var(--bg-white);
            border-top: 1px solid var(--border-color);
            padding: 15px 30px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .api-key-input {
            padding: 8px 12px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            font-size: 14px;
            width: 300px;
        }

        .api-key-save {
            padding: 8px 16px;
            background: var(--huawei-red);
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
        }

        .api-key-save:hover {
            background: var(--huawei-red-dark);
        }

        .api-status {
            font-size: 14px;
            color: var(--text-secondary);
            margin-left: 10px;
        }

        .api-status.connected {
            color: var(--positive-green);
        }

        .api-status.disconnected {
            color: var(--negative-red);
        }

        /* 加载动画 */
        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid var(--border-color);
            border-radius: 50%;
            border-top-color: var(--huawei-red);
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .nav-title::before {
            content: '';
            width: 4px;
            height: 24px;
            background: var(--huawei-red);
            border-radius: 2px;
        }

        .nav-filters {
            padding: 20px 30px;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .filter-row {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            flex-wrap: wrap;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            min-width: 200px;
        }

        .filter-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .filter-label::before {
            content: '';
            width: 3px;
            height: 12px;
            background: var(--huawei-red);
            border-radius: 1px;
        }

        .filter-options {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .filter-btn {
            padding: 6px 14px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            background: var(--bg-white);
            color: var(--text-secondary);
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .filter-btn:hover {
            border-color: var(--huawei-red);
            color: var(--huawei-red);
            background: var(--hover-bg);
        }

        .filter-btn.active {
            background: var(--huawei-red);
            border-color: var(--huawei-red);
            color: var(--bg-white);
        }

        .filter-btn.all-btn {
            border-color: var(--text-tertiary);
            color: var(--text-tertiary);
            font-weight: 600;
        }

        .filter-btn.all-btn.active {
            background: var(--text-tertiary);
            color: var(--bg-white);
        }

        .search-box {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .search-input {
            padding: 8px 16px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            width: 320px;
            font-size: 13px;
            transition: all 0.2s;
        }

        .search-input:focus {
            outline: none;
            border-color: var(--huawei-red);
            box-shadow: 0 0 0 3px rgba(207, 10, 44, 0.1);
        }

        /* -------------------------- 主体布局（上下结构） -------------------------- */
        .main-container { 
            display: flex; 
            flex-direction: column;
            padding: 20px 30px;
            gap: 20px;
        }

        /* 上半部分：侧边栏指标体系 + 口径定义面板 */
        .upper-section {
            display: flex;
            gap: 20px;
            height: 420px;
        }

        /* 侧边栏指标体系（支持多选） */
        .sidebar {
            width: 30%;
            background: var(--bg-white);
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            overflow-y: auto;
            padding: 20px 0;
            flex-shrink: 0;
        }

        /* 口径定义面板（支持多指标展示） */
        .definition-panel {
            flex: 7;
            background: var(--bg-white);
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            padding: 20px;
            overflow-y: auto;
        }

        .metric-level { 
            padding: 0 15px; 
        }

        .level-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            padding: 12px 0;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
        }

        .level-title:hover { 
            color: var(--huawei-red); 
        }

        .metric-list { 
            padding: 10px 0; 
            display: none; 
        }

        .metric-list.active { 
            display: block; 
        }

        .metric-item {
            padding: 10px 15px;
            font-size: 13px;
            color: var(--text-secondary);
            cursor: pointer;
            border-radius: 4px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }

        .metric-item:hover { 
            background: var(--hover-bg); 
            color: var(--huawei-red); 
        }

        .metric-item.active { 
            background: var(--huawei-red); 
            color: var(--bg-white); 
        }

        /* 口径定义面板（支持多指标展示） */
        .definition-panel {
            flex: 1;
            background: var(--bg-white);
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            padding: 20px;
            overflow-y: auto;
        }

        .definition-panel-header {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .definition-panel-header::before {
            content: '';
            width: 3px;
            height: 16px;
            background: var(--huawei-red);
            border-radius: 1px;
        }

        .definition-metric-block {
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px dashed var(--border-color);
        }

        .definition-metric-block:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .definition-metric-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--huawei-red);
            margin-bottom: 10px;
        }

        .definition-section {
            margin-bottom: 12px;
        }

        .definition-section-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        .definition-content {
            font-size: 12px;
            color: var(--text-secondary);
            line-height: 1.8;
        }

        .definition-content ul {
            margin-left: 20px;
            margin-top: 4px;
        }

        .definition-content li {
            margin-bottom: 4px;
        }

        .definition-content .highlight {
            color: var(--huawei-red);
            font-weight: 600;
        }

        /* AI分析内容样式 - 卡片式设计 */
        .ai-analysis-content {
            all: initial;
            font-family: 'HarmonyOS Sans SC', 'Microsoft YaHei', sans-serif;
            color: var(--text-primary);
            line-height: 1.6;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .ai-analysis-content * {
            all: unset;
            display: block;
        }

        .ai-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            border-left: 4px solid var(--huawei-red);
        }

        .ai-card-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--huawei-red);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .ai-card-title::before {
            content: '';
            width: 4px;
            height: 20px;
            background: var(--huawei-red);
            border-radius: 2px;
        }

        .ai-card-content {
            font-size: 14px;
            color: var(--text-secondary);
            line-height: 1.8;
        }

        .ai-card-content p {
            margin-bottom: 12px;
        }

        .ai-card-content p:last-child {
            margin-bottom: 0;
        }

        .ai-card-content ul, .ai-card-content ol {
            margin-left: 20px;
            margin-top: 8px;
            margin-bottom: 12px;
        }

        .ai-card-content li {
            margin-bottom: 8px;
            padding-left: 8px;
        }

        .ai-card-content strong {
            color: var(--huawei-red);
            font-weight: 600;
        }

        /* 不同类型的卡片用不同的边框颜色 */
        .ai-card.overview {
            border-left-color: #1890ff;
        }

        .ai-card.overview .ai-card-title::before {
            background: #1890ff;
        }

        .ai-card.top-apps {
            border-left-color: #52c41a;
        }

        .ai-card.top-apps .ai-card-title::before {
            background: #52c41a;
        }

        .ai-card.problems {
            border-left-color: #faad14;
        }

        .ai-card.problems .ai-card-title::before {
            background: #faad14;
        }

        .ai-card.suggestions {
            border-left-color: #722ed1;
        }

        .ai-card.suggestions .ai-card-title::before {
            background: #722ed1;
        }

        .ai-card.trends {
            border-left-color: #eb2f96;
        }

        .ai-card.trends .ai-card-title::before {
            background: #eb2f96;
        }

        /* 确保口径定义部分的样式不受影响 */
        #definitionContent {
            isolation: isolate;
        }

        /* 恢复原始的口径定义样式 */
        #definitionContent .definition-metric-block {
            margin-bottom: 20px;
        }

        #definitionContent .definition-metric-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--huawei-red);
            margin-bottom: 10px;
        }

        #definitionContent .definition-section {
            margin-bottom: 15px;
        }

        #definitionContent .definition-section-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        #definitionContent .definition-content {
            font-size: 12px;
            color: var(--text-secondary);
            line-height: 1.8;
        }

        #definitionContent .definition-content ul {
            margin-left: 20px;
            margin-top: 4px;
        }

        #definitionContent .definition-content li {
            margin-bottom: 4px;
        }

        #definitionContent .definition-content .highlight {
            color: var(--huawei-red);
            font-weight: 600;
        }

        /* 下半部分：数据表格 + 数据解读 */
        .lower-section {
            background: var(--bg-white);
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            position: relative;
        }

        .table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
        }

        .table-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .table-title::before {
            content: '';
            width: 4px;
            height: 20px;
            background: var(--huawei-red);
            border-radius: 2px;
        }

        .time-period-select {
            display: flex;
            gap: 8px;
        }

        .time-period-btn {
            padding: 6px 14px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            background: var(--bg-white);
            color: var(--text-secondary);
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .time-period-btn:hover {
            border-color: var(--huawei-red);
            color: var(--huawei-red);
            background: var(--hover-bg);
        }

        .time-period-btn.active {
            background: var(--huawei-red);
            border-color: var(--huawei-red);
            color: var(--bg-white);
        }

        .table-wrapper {
            overflow: auto;
            max-height: 500px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            min-width: 1200px;
        }

        .data-table th, .data-table td {
            padding: 12px 10px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
            white-space: nowrap;
        }

        .data-table th {
            background: var(--bg-gray);
            font-weight: 600;
            color: var(--text-primary);
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .data-table tr:hover {
            background: var(--hover-bg);
        }

        .data-table td:first-child {
            font-weight: 500;
            color: var(--huawei-red);
            position: sticky;
            left: 0;
            background: var(--bg-white);
            z-index: 2;
            cursor: pointer;
        }

        .data-table td:first-child:hover {
            text-decoration: underline;
        }

        /* 图表容器样式 */
        .chart-container {
            margin-top: 20px;
            padding: 20px;
            background: var(--bg-white);
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
        }

        .chart-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .chart-title::before {
            content: '';
            width: 4px;
            height: 20px;
            background: var(--huawei-red);
            border-radius: 2px;
        }

        .chart-actions {
            display: flex;
            gap: 10px;
        }

        .chart-btn {
            padding: 6px 14px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            background: var(--bg-white);
            color: var(--text-secondary);
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .chart-btn:hover {
            border-color: var(--huawei-red);
            color: var(--huawei-red);
            background: var(--hover-bg);
        }

        .chart-btn.active {
            background: var(--huawei-red);
            border-color: var(--huawei-red);
            color: var(--bg-white);
        }

        .chart-content {
            width: 100%;
            height: 400px;
        }

        .data-table th:first-child {
            position: sticky;
            left: 0;
            z-index: 3;
        }

        /* 同环比样式 */
        .mom-positive {
            color: var(--negative-red);
        }
        .mom-negative {
            color: var(--positive-green);
        }
        .yoy-positive {
            color: var(--negative-red);
        }
        .yoy-negative {
            color: var(--positive-green);
        }

        /* 数据解读模块 */
        .interpretation-section {
            border-top: 1px solid var(--border-color);
            padding-top: 20px;
        }

        .interpretation-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .interpretation-title::before {
            content: '';
            width: 3px;
            height: 16px;
            background: var(--huawei-red);
            border-radius: 1px;
        }

        .interpretation-content {
            display: flex;
            flex-direction: column;
            gap: 12px;
            font-size: 13px;
            color: var(--text-secondary);
            line-height: 1.8;
        }

        .interpretation-block {
            padding: 12px 15px;
            background: var(--bg-gray);
            border-radius: 6px;
        }

        .interpretation-block-title {
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        /* 滚动条美化 */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-gray);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--text-tertiary);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--text-secondary);
        }
    </style>
</head>
<body>
    <!-- 顶部导航栏 -->
    <div class="top-nav">
        <div class="nav-header">
            <div class="nav-title">终端云服务数据看板</div>
        </div>
        
        <!-- API Key配置区域 -->
        <div class="api-key-section">
            <label for="apiKeyInput">大模型API Key：</label>
            <input type="text" id="apiKeyInput" class="api-key-input" placeholder="请输入API Key" />
            <button class="api-key-save" onclick="saveApiKey()">保存</button>
            <span class="api-status" id="apiStatus">未配置</span>
        </div>

        <div class="nav-filters">
            <!-- 第一行：区域+统计口径+设备类型+应用区分 -->
            <div class="filter-row">
                <!-- 区域筛选 -->
                <div class="filter-group">
                    <div class="filter-label">区域</div>
                    <div class="filter-options" id="regionOptions">
                        <button class="filter-btn active" data-value="global" onclick="selectRegion('global')">全球</button>
                        <button class="filter-btn" data-value="domestic" onclick="selectRegion('domestic')">国内</button>
                        <button class="filter-btn" data-value="overseas" onclick="selectRegion('overseas')">海外</button>
                    </div>
                </div>

                <!-- 单双框 -->
                <div class="filter-group">
                    <div class="filter-label">单双框</div>
                    <div class="filter-options" id="frameOptions">
                        <button class="filter-btn active" data-value="all" onclick="selectFrame('all')">全量</button>
                        <button class="filter-btn" data-value="single" onclick="selectFrame('single')">单框架</button>
                        <button class="filter-btn" data-value="dual" onclick="selectFrame('dual')">双框架</button>
                    </div>
                </div>

                <!-- 统计口径 -->
                <div class="filter-group">
                    <div class="filter-label">统计口径</div>
                    <div class="filter-options" id="caliberOptions">
                        <button class="filter-btn active" data-value="account" onclick="selectCaliber('account')">按账号统计</button>
                        <button class="filter-btn" data-value="device" onclick="selectCaliber('device')">按设备统计</button>
                    </div>
                </div>

                <!-- 设备类型 -->
                <div class="filter-group">
                    <div class="filter-label">
                        设备类型
                        <button class="filter-btn all-btn" onclick="toggleAll('deviceType')" style="padding: 3px 10px; font-size: 12px;">全部</button>
                    </div>
                    <div class="filter-options" id="deviceTypeOptions">
                        <button class="filter-btn active" data-value="phone" onclick="toggleOption('deviceType', 'phone')">手机</button>
                        <button class="filter-btn" data-value="tablet" onclick="toggleOption('deviceType', 'tablet')">平板</button>
                        <button class="filter-btn" data-value="pc" onclick="toggleOption('deviceType', 'pc')">PC</button>
                        <button class="filter-btn" data-value="tv" onclick="toggleOption('deviceType', 'tv')">大屏</button>
                        <button class="filter-btn" data-value="watch" onclick="toggleOption('deviceType', 'watch')">手表</button>
                        <button class="filter-btn" data-value="car" onclick="toggleOption('deviceType', 'car')">车机</button>
                        <button class="filter-btn" data-value="speaker" onclick="toggleOption('deviceType', 'speaker')">音箱</button>
                        <button class="filter-btn" data-value="glasses" onclick="toggleOption('deviceType', 'glasses')">眼镜</button>
                        <button class="filter-btn" data-value="headphone" onclick="toggleOption('deviceType', 'headphone')">耳机</button>
                    </div>
                </div>

                <!-- 应用区分 -->
                <div class="filter-group">
                    <div class="filter-label">
                        应用区分
                        <button class="filter-btn all-btn" onclick="toggleAll('appType')" style="padding: 3px 10px; font-size: 12px;">全部</button>
                    </div>
                    <div class="filter-options" id="appTypeOptions">
                        <button class="filter-btn active" data-value="first-party" onclick="toggleOption('appType', 'first-party')">一方应用</button>
