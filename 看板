                        areaStyle: {
                            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                                { offset: 0, color: 'rgba(207, 10, 44, 0.3)' },
                                { offset: 1, color: 'rgba(207, 10, 44, 0.1)' }
                            ])
                        }
                    }
                ]
            };
            
            openFloatingChart(`${appName} - ${metricDefinitions[metric].title} 历史趋势`, 'history', option);
        }

        // 渲染应用对比图表（悬浮式）
        function renderAppComparisonChart(apps, metric) {
            const comparisonData = generateAppComparisonData(apps, metric);
            const option = {
                tooltip: {
                    trigger: 'axis',
                    axisPointer: {
                        type: 'shadow'
                    }
                },
                grid: {
                    left: '3%',
                    right: '4%',
                    bottom: '3%',
                    containLabel: true
                },
                xAxis: {
                    type: 'category',
                    data: comparisonData.appNames,
                    axisLabel: {
                        interval: 0,
                        rotate: 30
                    }
                },
                yAxis: {
                    type: 'value'
                },
                series: [
                    {
                        name: metricDefinitions[metric].title,
                        type: 'bar',
                        data: comparisonData.data,
                        itemStyle: {
                            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                                { offset: 0, color: '#CF0A2C' },
                                { offset: 1, color: '#E64340' }
                            ])
                        }
                    }
                ]
            };
            
            openFloatingChart(`${metricDefinitions[metric].title} 应用对比`, 'comparison', option);
        }

        // 切换应用对比图表显示
        function toggleComparisonChart() {
            // 获取当前应用列表
            let appsToShow = [];
            if (state.appType.includes('first-party')) appsToShow = appsToShow.concat(firstPartyApps);
            if (state.appType.includes('third-party')) appsToShow = appsToShow.concat(thirdPartyApps);

            if (state.appCategory.length > 0 && state.appCategory.length < 10) {
                appsToShow = appsToShow.filter(app => state.appCategory.includes(app.category1));
            }

            if (state.subCategory.length > 0) {
                appsToShow = appsToShow.filter(app => state.subCategory.includes(app.category2));
            }

            if (state.appName) {
                const searchTerm = state.appName.toLowerCase();
                appsToShow = appsToShow.filter(app => app.name.toLowerCase().includes(searchTerm));
            }
            
            if (appsToShow.length > 0) {
                const metric = state.selectedMetrics[0]; // 使用第一个选中的指标
                renderAppComparisonChart(appsToShow, metric);
            }
        }

        // -------------------------- 表格点击事件处理 --------------------------
        function addTableClickEvents() {
            const table = document.getElementById('dataTable');
            const rows = table.querySelectorAll('tbody tr');
            
            rows.forEach(row => {
                const appNameCell = row.querySelector('td:first-child');
                appNameCell.addEventListener('click', () => {
                    const appName = appNameCell.textContent;
                    const metric = state.selectedMetrics[0]; // 使用第一个选中的指标
                    renderAppHistoryChart(appName, metric);
                });
            });
        }

        // -------------------------- 初始化 --------------------------
        window.addEventListener('resize', () => {
            if (floatingChart) floatingChart.resize();
        });

        // 大模型集成功能
        // 保存API Key
        function saveApiKey() {
            const apiKeyInput = document.getElementById('apiKeyInput');
            const apiStatus = document.getElementById('apiStatus');
            const apiKey = apiKeyInput.value.trim();
            
            if (apiKey) {
                state.apiKey = apiKey;
                state.useAi = true;
                localStorage.setItem('aiApiKey', apiKey);
                localStorage.setItem('useAi', 'true');
                apiStatus.textContent = '已连接';
                apiStatus.className = 'api-status connected';
                alert('API Key 保存成功！');
            } else {
                apiStatus.textContent = '未配置';
                apiStatus.className = 'api-status disconnected';
                state.apiKey = '';
                state.useAi = false;
                localStorage.removeItem('aiApiKey');
                localStorage.setItem('useAi', 'false');
            }
        }

        // 调用大模型生成分析
        async function generateAiAnalysis(appDataList) {
            const apiStatus = document.getElementById('apiStatus');
            
            if (!state.apiKey) {
                apiStatus.textContent = '未配置API Key';
                apiStatus.className = 'api-status disconnected';
                return null;
            }
            
            apiStatus.innerHTML = '<div class="loading-spinner"></div> 生成分析中...';
            
            try {
                // 准备数据
                const selectedMetrics = state.selectedMetrics;
                const timePeriod = state.currentTimePeriod;
                const region = state.region === 'global' ? '全球' : state.region === 'domestic' ? '国内' : '海外';
                
                // 构建分析请求数据
                const analysisData = {
                    appDataList: appDataList,
                    selectedMetrics: selectedMetrics,
                    timePeriod: timePeriod,
                    region: region,
                    metrics: selectedMetrics.map(metric => ({
                        key: metric,
                        name: metricDefinitions[metric].title
                    }))
                };
                
                // 调用大模型API（支持Qwen3.5Plus API）
                const response = await fetch('https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${state.apiKey}`
                    },
                    body: JSON.stringify({
                        model: 'qwen-plus',
                        messages: [
                            {
                                role: 'system',
                                content: `你是一位专业的数据分析专家，擅长分析移动应用数据并生成结构清晰、逻辑严谨的洞察报告。请根据提供的数据，生成一份专业的分析报告，要求如下：

【输出格式】（必须严格按此格式输出）

<div class="ai-card overview">
<div class="ai-card-title">📈 整体大盘分析</div>
<div class="ai-card-content">
<p>（在这里用一段完整、连贯的话来描述整体大盘情况，包括数据表现、环比同比变化、趋势判断等，写成一段完整的分析段落，不要碎片化的短语）</p>
</div>
</div>

<div class="ai-card top-apps">
<div class="ai-card-title">🏆 头部应用亮点</div>
<div class="ai-card-content">
<p>（在这里用连贯的段落描述头部应用的亮点，包括具体应用名称、核心优势、数据表现等，写成完整的分析段落）</p>
<ul>
<li>（每个列表项也要写成完整的句子，不要碎片化）</li>
<li>（例如：微信在DAU指标上表现最为突出，达到5.2亿，环比增长3.2%，稳居社交类应用首位）</li>
</ul>
</div>
</div>

<div class="ai-card problems">
<div class="ai-card-title">⚠️ 问题应用诊断</div>
<div class="ai-card-content">
<p>（用连贯的段落分析问题应用，指出具体问题、可能原因和改进建议，写成完整的分析段落）</p>
</div>
</div>

<div class="ai-card suggestions">
<div class="ai-card-title">💡 运营建议</div>
<div class="ai-card-content">
<p>（用连贯的段落阐述运营建议，说明具体的策略和实施方案）</p>
<ul>
<li>（每条建议都要写成完整的句子，包含具体的操作步骤和预期效果）</li>
<li>（例如：建议优化新手引导流程，通过增加趣味性任务和即时奖励机制，提升新用户次日留存率5%以上）</li>
</ul>
</div>
</div>

<div class="ai-card trends">
<div class="ai-card-title">🔮 趋势洞察</div>
<div class="ai-card-content">
<p>（用连贯的段落分析行业趋势，结合当前互联网发展动向和市场变化）</p>
</div>
</div>

【排版强制要求】
1. 必须使用上述HTML结构，每个卡片独立完整
2. 每个<p>标签内必须是一段完整、连贯的话，不能是碎片化的词语或短语
3. 每个<li>标签内也必须是一句完整的话
4. 段落之间要有自然的逻辑衔接
5. 重点数据用<strong>包裹
6. 禁止输出碎片化的词语如"增长强劲"、"表现良好"等独立词语，必须构成完整句子`
                            },
                            {
                                role: 'user',
                                content: `请分析以下应用数据：\n${JSON.stringify(analysisData, null, 2)}\n\n请严格按照上述HTML格式输出，每个段落必须是完整连贯的句子，不要碎片化。`
                            }
                        ],
                        temperature: 0.7
                    })
                });
                
                if (!response.ok) {
                    throw new Error(`API请求失败: ${response.status}`);
                }
                
                const data = await response.json();
                let analysis = data.choices[0].message.content;
                
                // 清理大模型生成的内容，确保不会影响页面样式
                // 移除可能的样式标签
                analysis = analysis.replace(/<style[\s\S]*?<\/style>/gi, '');
                // 移除可能的脚本标签
                analysis = analysis.replace(/<script[\s\S]*?<\/script>/gi, '');
                // 确保内容在正确的容器中
                analysis = `<div class="ai-analysis-content">${analysis}</div>`;
                
                apiStatus.textContent = '已连接';
                apiStatus.className = 'api-status connected';
                
                return analysis;
            } catch (error) {
                console.error('大模型调用失败:', error);
                apiStatus.textContent = '连接失败';
                apiStatus.className = 'api-status disconnected';
                return null;
            }
        }

        // 初始化API Key
        function initApiKey() {
            const apiKeyInput = document.getElementById('apiKeyInput');
            const apiStatus = document.getElementById('apiStatus');
            
            if (state.apiKey) {
                apiKeyInput.value = state.apiKey;
                apiStatus.textContent = '已连接';
                apiStatus.className = 'api-status connected';
            } else {
                apiStatus.textContent = '未配置';
                apiStatus.className = 'api-status disconnected';
            }
        }

        // 生成分析报告
        async function generateReport() {
            if (!state.apiKey) {
                alert('请先配置API Key');
                return;
            }
            
            const container = document.getElementById('interpretationContent');
            container.innerHTML = '<div style="text-align: center; padding: 40px;"><div class="loading-spinner"></div><p style="margin-top: 20px;">AI正在生成分析报告...</p></div>';
            
            // 获取当前表格数据
            const appDataList = getCurrentAppDataList();
            const aiAnalysis = await generateAiAnalysis(appDataList);
            if (aiAnalysis) {
                container.innerHTML = aiAnalysis;
            } else {
                container.innerHTML = '<div class="definition-content">生成分析报告失败，请检查API配置。</div>';
            }
        }

        // 获取当前表格数据
        function getCurrentAppDataList() {
            const appDataList = [];
            const table = document.getElementById('dataTable');
            if (!table) return appDataList;
            
            const rows = table.querySelectorAll('tbody tr');
            rows.forEach(row => {
                const appName = row.querySelector('td:first-child')?.textContent?.trim();
                if (appName && appName !== '暂无数据') {
                    const cells = row.querySelectorAll('td');
                    const appData = {
                        name: appName,
                        metrics: {}
                    };
                    
                    // 解析每个指标数据
                    if (cells.length > 1) {
                        const metricKeys = Object.keys(metricDefinitions);
                        metricKeys.forEach((key, index) => {
                            if (cells[index + 1]) {
                                const cellText = cells[index + 1].textContent || '';
                                const valueMatch = cellText.match(/[\d,]+/);
                                if (valueMatch) {
                                    const rawValue = parseInt(valueMatch[0].replace(/,/g, ''));
                                    appData.metrics[key] = {
                                        rawValue: rawValue,
                                        displayValue: cellText,
                                        trend: Math.random() > 0.5 ? 'up' : 'down'
                                    };
                                }
                            }
                        });
                    }
                    appDataList.push(appData);
                }
            });
            
            return appDataList;
        }

        // 初始渲染
        initApiKey();
        renderSubCategoryOptions();
        renderTable();
        renderDefinitionPanel();
        
        // 添加表格点击事件
        setTimeout(addTableClickEvents, 100);
    </script>
</body>
</html>
